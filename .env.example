# ================================================================
# PLANTILLA DE VARIABLES D'ENTORN — viscalaterra.cat
# Copia aquest fitxer com a .env i omple els valors reals.
# MAI afegeixis .env al repositori.
# ================================================================

# --- Base de dades ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=viscalaterra
DB_USER=
DB_PASSWORD=

# --- Backend ---
NODE_ENV=development
PORT=3000

# --- Autenticació JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Frontend ---
VITE_API_URL=http://localhost:3000
